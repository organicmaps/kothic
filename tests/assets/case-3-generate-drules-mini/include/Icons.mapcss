/*
Generic POIs.
Declare _before_ all concrete POIs to avoid styles overrides.
*/

node|z18-[tourism],
area|z18-[tourism],
node|z18-[office],
area|z18-[office],
node|z18-[craft],
area|z18-[craft],
node|z19-[amenity],
area|z19-[amenity],
{text: name; text-color: @poi_label; text-offset: 1;}

node|z19-[amenity],
area|z19-[amenity],
{font-size: 10;}

node|z18-[office],
area|z18-[office],
{icon-image: office-m.svg;}

node|z18-[craft],
area|z18-[craft],
{icon-image: craft-m.svg;}

node|z16-[shop],
area|z16-[shop],
{icon-min-distance: 10;}
node|z18-[shop],
area|z18-[shop],
{icon-image: shop-m.svg;}

